{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "nodenext",
    "types": ["@playwright/test", "node"]
  },
  "include": ["tests/**/*.ts", "e2e/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
